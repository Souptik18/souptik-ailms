NODE_ENV=development
API_PORT=4001
APP_ORIGIN=http://localhost:4000
SESSION_COOKIE_NAME=kiitx_session
FIRESTORE_SESSION_COLLECTION=auth_sessions
FIRESTORE_USER_ROLE_COLLECTION=user_roles
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Prefer xAI Grok for onboarding roadmap and AI LMS tutor generation.
XAI_API_KEY=your-xai-grok-api-key
XAI_MODEL=grok-4.20-reasoning
# Optional Groq fallback for non-xAI workloads.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
YOUTUBE_API_KEY=your-youtube-api-key
RAPIDAPI_LINKEDIN_JOBS_KEY=your-rapidapi-linkedin-jobs-key
